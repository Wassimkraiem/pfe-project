FLASK_ENV=development
AWS_REGION=us-east-1
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_INITIAL_ADMIN_PASSWORD=admin
OPENSEARCH_AUTH_ADMIN=admin
SENTRY_DSN=
API_KEYS=key1

REDIS_URL=redis://localhost:6379/0
SEARCH_CACHE_TTL=300
SEARCH_CACHE_ENABLED=true

DISABLE_EMBEDDINGS=false
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
OPENAI_API_KEY=
VIDEOS_READ_ALIAS=videos_read
VIDEOS_WRITE_ALIAS=videos_write
ADVANCED_SEARCH_OPENAI_RERANK_MODE=last_resort
OPENAI_RERANK_TIMEOUT_SECONDS=2
ADVANCED_SEARCH_OPENAI_RERANK_WEAK_GAP=0.015
ADVANCED_SEARCH_OPENAI_RERANK_WEAK_HEURISTIC=0.10
ADVANCED_SEARCH_RERANK_TOP_N=30
ADVANCED_SEARCH_TOP_RANK_BONUS=0.05
ADVANCED_SEARCH_TOP_RANK_2_3_BONUS=0.02
