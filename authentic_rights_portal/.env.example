# Copy to .env.local and fill in values. For Netlify, set these in Site settings → Environment variables.

# Backend API base URL (no trailing slash)
NEXT_PUBLIC_API_URL=https://mut3axhdpf.us-east-1.awsapprunner.com

# Chat API service used by the in-app assistant
CHAT_API_URL=http://localhost:8003/api/v1/chat
CHAT_API_KEY=change-me

# Clerk (get from https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Optional: JWT template name for API auth (recommended if backend validates custom aud/claims)
NEXT_PUBLIC_CLERK_JWT_TEMPLATE=api
