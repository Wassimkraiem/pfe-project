# ==============================================
# Authentic Rights API - Environment Variables
# ==============================================
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to git!

# ==============================================
# Application Settings
# ==============================================
PROJECT_NAME=Authentic Rights API

# Frontend URL for redirects after payment completion
FRONTEND_URL=http://localhost:3000

# CORS allowed origins (comma-separated for multiple frontends)
# Include both localhost and 127.0.0.1 - browsers treat them as different origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# Celery + Redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

DATABASE_URL=postgresql+asyncpg://postgres:your_password@db:5432/authentic_rights

# PostgreSQL Database Settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=authentic_rights

STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_PRICE_ID_MONTHLY=price_your_monthly_price_id
STRIPE_PRICE_ID_YEARLY=price_your_yearly_price_id
STRIPE_API_VERSION=

CLERK_SECRET_KEY=sk_test_your_clerk_secret
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json
# Session JWT expiration in seconds (default: 86400 = 24 hours)
CLERK_SESSION_TOKEN_EXPIRES_IN_SECONDS=86400

# ==============================================
# SMTP Email Configuration
# ==============================================
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_REGION=us-east-1
SMTP_USE_TLS=true
EMAIL_SENDER=noreply@bviral.com
EMAIL_SENDER_NAME=BVIRAL Sales Team

# ==============================================
# SMS SDK Configuration
# ==============================================
SMS_BASE_URL=
SMS_X_API_KEY=
SMS_API_KEY=
RENEWAL_GRACE_PERIOD_MINUTES=5

# ==============================================
# Startup Checks
# ==============================================
# Optional DynamoDB startup connectivity check
STARTUP_ENABLE_DDB_CHECK=false
STARTUP_DDB_CHECK_TIMEOUT_SECONDS=5
DDB_TABLE_NAME=
# If empty, app falls back to AWS_REGION/AWS_DEFAULT_REGION
DDB_REGION=
# Optional endpoint override (useful for localstack)
DDB_ENDPOINT_URL=

# ==============================================
# Canto API Configuration
# ==============================================
CANTO_AUTH_URL=
CANTO_APP_ID=
CANTO_APP_SECRET=
# Canto group UUID used for the basic plan (defaults to production value in code)
CANTO_BASIC_PLAN_GROUP_ID=

# ==============================================
# Slack Notifications
# ==============================================
# Slack incoming webhook URL (leave empty to disable)
SLACK_WEBHOOK_URL=
