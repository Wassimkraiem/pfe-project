APP_NAME=Agentic Helper API
APP_API_KEY=change-me
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=agentic_helper_knowledge
QDRANT_VECTOR_NAME=
QDRANT_VECTOR_SIZE=1536
QDRANT_TIMEOUT_SECONDS=10
OPENAI_API_KEY=your-openai-key
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_CHAT_TEMPERATURE=0.2
OPENAI_CLASSIFIER_MODEL=gpt-4o-mini
OPENAI_CLASSIFIER_TEMPERATURE=0.0
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=agentic-helper
LANGSMITH_WORKSPACE_ID=
CHATBOT_SYSTEM_PROMPT_FILE=data/prompts/bviral_system_prompt.txt
CHATBOT_SYSTEM_PROMPT_LANGSMITH=agentic-helper-chatbot-system
CHATBOT_SYSTEM_PROMPT=You are a helpful assistant. Use retrieved context when available. If context is missing, say you are answering from general knowledge.
CHATBOT_RAG_CLASSIFIER_PROMPT_LANGSMITH=
CHATBOT_RAG_CLASSIFIER_PROMPT=You are a routing classifier for a chatbot with a document knowledge base. Return exactly one token: RAG or DIRECT. Return RAG when the answer likely depends on domain-specific facts, policies, pricing, billing, product or company details, or previously ingested resources. If a question is vague but business-contextual (for example: should I pay, how does it work, is this covered), choose RAG. Return DIRECT for generic chitchat, rewriting, brainstorming, or questions answerable without the knowledge base.
CHATBOT_ROUTER_PROMPT_LANGSMITH=
CHATBOT_ROUTER_PROMPT=You route user messages for the BVIRAL assistant. Return one route: CHAT_RAG, VIDEO_SEARCH, DIRECT, OUT_OF_SCOPE, or SUPPORT_HANDOFF.
CHATBOT_INTEREST_CLASSIFIER_PROMPT_LANGSMITH=agentic-helper-chatbot-interest-classifier
CHATBOT_INTEREST_CLASSIFIER_PROMPT=You classify user intent for sales or engagement interest. Return exactly one token: INTERESTED, NOT_INTERESTED, or UNCLEAR. INTERESTED means user shows willingness to proceed or asks next steps. NOT_INTERESTED means user declines or wants to stop. UNCLEAR means neutral or insufficient signal.
CHATBOT_INTERESTED_RESPONSE_PROMPT_LANGSMITH=agentic-helper-chatbot-interested-response
CHATBOT_INTERESTED_RESPONSE_PROMPT=The user is INTERESTED. Respond with momentum and clear next steps. If appropriate, include [SUBMISSION_URL] once.
CHATBOT_NOT_INTERESTED_RESPONSE_PROMPT_LANGSMITH=agentic-helper-chatbot-not-interested-response
CHATBOT_NOT_INTERESTED_RESPONSE_PROMPT=The user is NOT_INTERESTED. Respond empathetically, acknowledge their decision, and avoid pressure.
CHATBOT_VIDEO_FILTER_EXTRACTOR_PROMPT_LANGSMITH=agentic-helper-chatbot-video-filter-extractor
CHATBOT_VIDEO_FILTER_EXTRACTOR_PROMPT_FILE=data/prompts/video_search_filter_extractor_prompt.txt
VIDEO_SEARCH_SYSTEM_PROMPT_LANGSMITH=agentic-helper-video-search-system
VIDEO_SEARCH_SYSTEM_PROMPT_FILE=data/prompts/video_search_system_prompt.txt
VIDEO_SEARCH_SYSTEM_PROMPT=You are a video search assistant. Help users find videos using the available tools. Present results clearly with video titles, descriptions, and IDs.
VIDEOS_SEARCH_API_URL=http://localhost:5000
VIDEOS_SEARCH_API_FALLBACK_URLS=http://videos-search-api:5000,http://host.docker.internal:5000
VIDEOS_SEARCH_API_KEY=key1
FRONTEND_SEARCH_URL=http://localhost:3000/search
VIDEO_SEARCH_ADVANCED_ENABLED=true
VIDEO_SEARCH_TIMEOUT_SECONDS=12
VIDEO_SEARCH_RETRIES=1
VIDEO_SEARCH_FACET_CACHE_TTL_SECONDS=300
RAG_TOP_K=4
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
CHAT_MEMORY_MESSAGES=12
CHAT_HISTORY_REDIS_URL=
CHAT_HISTORY_TTL_SECONDS=2592000
